<?xml version="1.0" encoding="utf-8"?>
<statemachine
        xmlns="http://static.spryker.com"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://static.spryker.com http://static.spryker.com/oms-01.xsd">

    <process name="MolliePaymentStateMachine01" main="true">
        <subprocesses>
            <process>MollieRefund</process>
        </subprocesses>

        <states>
            <state name="new" reserved="true"/>
            <state name="payment pending" reserved="true" display="oms.state.payment-pending"/>
            <state name="payment pending next try" display="oms.state.payment-pending-next-try"/>
            <state name="paid" reserved="true" display="oms.state.paid"/>
            <state name="ready for shipment" reserved="true" display="oms.state.ready-for-shipment"/>
            <state name="shipped" display="oms.state.shipped"/>
            <state name="delivered" display="oms.state.delivered"/>
            <state name="closed" display="oms.state.closed"/>
            <state name="canceled" display="oms.state.canceled"/>
            <state name="expired" display="oms.state.expired"/>
            <state name="failed" display="oms.state.failed"/>
        </states>

        <transitions>
            <transition happy="true">
                <source>new</source>
                <target>payment pending</target>
                <event>start payment</event>
            </transition>

            <transition happy="true" condition="Mollie/IsPaymentStatusPaid">
                <source>payment pending</source>
                <target>paid</target>
                <event>check payment</event>
            </transition>

            <transition happy="true">
                <source>paid</source>
                <target>ready for shipment</target>
                <event>ready for shipment</event>
            </transition>

            <transition happy="true">
                <source>ready for shipment</source>
                <target>shipped</target>
                <event>ship order</event>
            </transition>

            <transition happy="true">
                <source>shipped</source>
                <target>delivered</target>
                <event>confirm delivery</event>
            </transition>

            <transition happy="true">
                <source>delivered</source>
                <target>closed</target>
                <event>close</event>
            </transition>

            <transition condition="Mollie/IsPaymentStatusFailed">
                <source>payment pending</source>
                <target>failed</target>
                <event>check payment</event>
            </transition>

            <transition condition="Mollie/IsPaymentStatusCancelled">
                <source>payment pending</source>
                <target>canceled</target>
                <event>check payment</event>
            </transition>

            <transition condition="Mollie/IsPaymentStatusExpired">
                <source>payment pending</source>
                <target>expired</target>
                <event>check payment</event>
            </transition>

            <transition>
                <source>payment pending</source>
                <target>payment pending next try</target>
                <event>return to payment pending</event>
            </transition>

            <transition>
                <source>payment pending next try</source>
                <target>payment pending</target>
                <event>pass</event>
            </transition>

            <transition>
                <source>failed</source>
                <target>closed</target>
                <event>close</event>
            </transition>

            <transition>
                <source>canceled</source>
                <target>closed</target>
                <event>close</event>
            </transition>

            <transition>
                <source>expired</source>
                <target>closed</target>
                <event>close</event>
            </transition>

        </transitions>

        <events>
            <event name="start payment" onEnter="true" />
            <event name="check payment" onEnter="true"/>
            <event name="ready for shipment" onEnter="true" command="Mollie/PaymentConfirmation"/>
            <event name="ship order" onEnter="true" />
            <event name="confirm delivery" onEnter="true"/>
            <event name="return to payment pending" timeout="1 minute"/>
            <event name="pass" onEnter="true"/>
            <event name="close" timeout="5 days"/>
        </events>

    </process>

    <process name="MollieRefund" file="RefundSubprocess/Refund01.xml"/>

</statemachine>
