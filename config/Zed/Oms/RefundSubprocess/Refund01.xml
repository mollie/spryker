<?xml version="1.0" encoding="utf-8"?>
<statemachine
        xmlns="http://static.spryker.com"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://static.spryker.com http://static.spryker.com/oms-01.xsd">

    <process name="MollieRefund">
        <states>
            <state name="refund pending" display="oms.state.refund-pending"/>
            <state name="refund processing" display="oms.state.refund-processing"/>
            <state name="refund failed" display="oms.state.refund-failed"/>
            <state name="refunded" display="oms.state.refunded"/>
            <state name="closed" display="oms.state.refund-closed"/>
        </states>

        <transitions>
            <transition>
                <source>delivered</source>
                <target>refund pending</target>
                <event>refund</event>
            </transition>

            <transition>
                <source>refund pending</source>
                <target>refund processing</target>
                <event>refund processing</event>
            </transition>

            <transition>
                <source>refund processing</source>
                <target>refunded</target>
                <event>payment refunded</event>
            </transition>

            <transition>
                <source>refund pending</source>
                <target>refunded</target>
                <event>payment refunded</event>
            </transition>

            <transition>
                <source>refund processing</source>
                <target>refund failed</target>
                <event>refund failed</event>
            </transition>

            <transition>
                <source>refund pending</source>
                <target>refund failed</target>
                <event>refund failed</event>
            </transition>

            <transition>
                <source>refunded</source>
                <target>closed</target>
                <event>close</event>
            </transition>

            <transition>
                <source>refund failed</source>
                <target>closed</target>
                <event>close</event>
            </transition>
        </transitions>

        <events>
            <event name="refund" manual="true" command="Mollie/Refund"/>
            <event name="payment refunded"/>
            <event name="refund processing"/>
            <event name="refund failed"/>
            <event name="close" timeout="5 days"/>
        </events>
    </process>

</statemachine>
