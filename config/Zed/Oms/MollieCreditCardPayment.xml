<?xml version="1.0" encoding="utf-8"?>
<statemachine
        xmlns="http://static.spryker.com"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://static.spryker.com http://static.spryker.com/oms-01.xsd">

    <process name="MollieCreditCardPayment" main="true">
        <states>
            <state name="new" reserved="true"/>
        </states>

        <transitions>
            <transition happy="true">
                <source>new</source>
                <target>payment pending</target>
                <event>start payment</event>
            </transition>
        </transitions>

        <events>
            <event name="start payment" onEnter="true" />
        </events>

        <subprocesses>
            <process>Payment</process>
            <process>Fulfillment</process>
            <process>Refund</process>
        </subprocesses>

    </process>
    <process name="Payment" file="Subprocess/Payment.xml"/>
    <process name="Fulfillment" file="Subprocess/Fulfillment.xml"/>
    <process name="Refund" file="Subprocess/Refund.xml"/>

</statemachine>
