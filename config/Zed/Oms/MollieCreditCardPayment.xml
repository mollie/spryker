<?xml version="1.0" encoding="utf-8"?>
<statemachine
        xmlns="http://static.spryker.com"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://static.spryker.com http://static.spryker.com/oms-01.xsd">

    <process name="MollieCreditCardPayment" main="true">
        <states>
            <state name="new" reserved="true"/>
            <state name="pending" reserved="true" display="oms.state.payment-pending"/>
            <state name="authorized" reserved="true"/>
            <state name="paid" reserved="true" />

            <state name="canceled" />
            <state name="expired" />
            <state name="failed"/>
        </states>

        <transitions>
            <transition happy="true">
                <source>new</source>
                <target>pending</target>
                <event>start payment</event>
            </transition>

            <transition happy="true">
                <source>pending</source>
                <target>authorized</target>
                <event>authorize payment</event>
            </transition>

            <transition happy="true">
                <source>authorized</source>
                <target>paid</target>
                <event>capture payment</event>
            </transition>

             <transition happy="true">
                <source>pending</source>
                <target>paid</target>
                <event>payment paid</event>
            </transition>

             <transition>
                <source>pending</source>
                <target>failed</target>
                <event>payment failed</event>
            </transition>

            <transition>
                <source>pending</source>
                <target>canceled</target>
                <event>cancel payment</event>
            </transition>

            <transition>
                <source>pending</source>
                <target>expired</target>
                <event>payment expired</event>
            </transition>

            <transition>
                <source>authorized</source>
                <target>canceled</target>
                <event>authorization canceled</event>
            </transition>

             <transition>
                <source>authorized</source>
                <target>expired</target>
                <event>authorization expired</event>
            </transition>

             <transition>
                <source>authorized</source>
                <target>failed</target>
                <event>authorization failed</event>
            </transition>
        </transitions>

        <events>
            <event name="start payment" onEnter="true" />
            <event name="authorize payment"/>
            <event name="capture payment"/>
            <event name="payment paid"/>
            <event name="cancel payment"/>
            <event name="payment expired"/>
            <event name="payment failed"/>
            <event name="authorization canceled"/>
            <event name="authorization expired"/>
            <event name="authorization failed"/>
        </events>
    </process>
</statemachine>
