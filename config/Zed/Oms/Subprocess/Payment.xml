<?xml version="1.0" encoding="utf-8"?>
<statemachine
        xmlns="http://static.spryker.com"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://static.spryker.com http://static.spryker.com/oms-01.xsd">

    <process name="Payment">
        <states>
            <state name="payment pending" reserved="true" display="oms.state.payment-pending"/>
            <state name="paid" reserved="true" display="oms.state.paid"/>
            <state name="canceled" display="oms.state.canceled"/>
            <state name="expired" display="oms.state.expired"/>
            <state name="failed" display="oms.state.failed"/>
        </states>

        <transitions>
            <transition happy="true">
                <source>payment pending</source>
                <target>paid</target>
                <event>payment paid</event>
            </transition>

            <transition>
                <source>payment pending</source>
                <target>failed</target>
                <event>payment failed</event>
            </transition>

            <transition>
                <source>payment pending</source>
                <target>canceled</target>
                <event>payment canceled</event>
            </transition>

            <transition>
                <source>payment pending</source>
                <target>expired</target>
                <event>payment expired</event>
            </transition>
        </transitions>

        <events>
            <event name="payment paid"/>
            <event name="payment canceled"/>
            <event name="payment expired"/>
            <event name="payment failed"/>
        </events>
    </process>

</statemachine>
