{% extends model('template') %}

{% define data = {
    form: form
} %}

{% block body %}
    {% set creditCardForm = data.form.children.mollieCreditCardPayment %}
    {% set vars = creditCardForm.vars %}
    {% set isMollieCreditCardComponentEnabled = vars.isMollieCreditCardComponentEnabled %}
    {% if isMollieCreditCardComponentEnabled %}
        {% include molecule('mollie-credit-card-component', 'Mollie') with {
            data: {
                form: data.form,
                profileId: vars.profileId,
                testMode: vars.testMode,
                jsSrc: vars.jsSrc,
            }
        } only %}
        {% else %}
        <div class="spacing-top--big">
            {{ 'checkout.payment.provider.mollieCreditCard.descriptionText' | trans }}
        </div>
    {% endif %}
{% endblock %}
