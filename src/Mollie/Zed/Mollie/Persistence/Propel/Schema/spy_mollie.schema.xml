<?xml version="1.0"?>
<database xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="zed" xsi:noNamespaceSchemaLocation="http://static.spryker.com/schema-01.xsd" namespace="Orm\Zed\Mollie\Persistence" package="src.Orm.Zed.Mollie.Persistence">

    <table name="spy_payment_mollie" phpName="SpyPaymentMollie">
        <column name="id_payment_mollie" required="true" type="INTEGER" autoIncrement="true" primaryKey="true"/>
        <column name="fk_sales_order" required="true" type="INTEGER"/>
        <column name="transaction_id" required="true" type="VARCHAR" size="255"/>
        <column name="status" required="true" type="VARCHAR" size="64"/>
        <column name="is_cancelable" type="BOOLEAN" />

        <column name="description" type="VARCHAR" size="255"/>
        <column name="sequence_type" required="true" type="VARCHAR" size="64"/>
        <column name="metadata" type="LONGVARCHAR"/>
        <column name="expires_at" type="TIMESTAMP"/>
        <column name="capture_before" type="TIMESTAMP"/>
        <column name="release_authorization_request" type="TIMESTAMP" required="false" />

        <foreign-key name="spy_payment_mollie-fk_sales_order" foreignTable="spy_sales_order" phpName="SpySalesOrder">
            <reference foreign="id_sales_order" local="fk_sales_order"/>
        </foreign-key>

        <index name="index-spy_payment_mollie-transaction_id">
            <index-column name="transaction_id"/>
        </index>

        <behavior name="timestampable"/>
        <id-method-parameter value="spy_payment_mollie_pk_seq"/>
    </table>

    <table name="spy_refund_mollie" phpName="SpyRefundMollie">
        <column name="id_refund_mollie" required="true" type="INTEGER" autoIncrement="true" primaryKey="true"/>
        <column name="fk_sales_order_item" required="true" type="INTEGER"/>
        <column name="description" type="VARCHAR" size="255"/>
        <column name="currency" type="VARCHAR" size="32"/>
        <column name="value" type="VARCHAR" size="32"/>
        <column name="status" required="true" type="VARCHAR" size="64"/>
        <column name="metadata" type="LONGVARCHAR"/>
        <column name="transaction_id" type="VARCHAR" size="255"/>
        <column name="refund_id" required="true" type="VARCHAR" size="255"/>
        <column name="created_at" type="TIMESTAMP"/>

        <foreign-key name="spy_refund_mollie-fk_sales_order_item" foreignTable="spy_sales_order_item" phpName="SpySalesOrderItem">
            <reference foreign="id_sales_order_item" local="fk_sales_order_item"/>
        </foreign-key>

        <index name="index-spy_refund_mollie-transaction_id">
            <index-column name="transaction_id"/>
        </index>

        <index name="index-spy_refund_mollie-refund_id">
            <index-column name="refund_id"/>
        </index>

        <behavior name="timestampable"/>
        <id-method-parameter value="spy_refund_mollie_pk_seq"/>
    </table>

    <table name="spy_mollie_order_item_payment_capture" phpName="SpyMollieOrderItemPaymentCapture">
        <column name="id_mollie_order_item_payment_capture" required="true" type="INTEGER" autoIncrement="true" primaryKey="true"/>
        <column name="fk_sales_order_item" required="true" type="INTEGER"/>
        <column name="capture_id" type="VARCHAR" size="255"/>
        <column name="transaction_id" type="VARCHAR" size="255"/>
        <column name="status" required="true" type="VARCHAR" size="64"/>
        <column name="description" type="VARCHAR" size="255"/>
        <column name="metadata" type="LONGVARCHAR"/>

        <foreign-key name="spy_capture_mollie_order_item-fk_sales_order_item" foreignTable="spy_sales_order_item" phpName="SpySalesOrderItem">
            <reference foreign="id_sales_order_item" local="fk_sales_order_item"/>
        </foreign-key>

        <index name="index-spy_capture_mollie_order_item-transaction_id">
            <index-column name="transaction_id"/>
        </index>

        <index name="index-spy_capture_mollie_order_item-capture_id">
            <index-column name="capture_id"/>
        </index>

        <behavior name="timestampable"/>
        <id-method-parameter value="spy_capture_mollie_order_item_pk_seq"/>
    </table>

    <table name="spy_mollie_payment_link" idMethod="native" allowPkInsert="true" phpName="SpyMolliePaymentLink">
        <column name="id_mollie_payment_link" required="true" type="INTEGER" autoIncrement="true" primaryKey="true"/>
        <column name="type" required="true" type="ENUM" valueSet="fixed, percentage"/>
        <column name="currency" required="true" type="VARCHAR" size="3"/>
        <column name="id" required="true" type="VARCHAR" />
        <column name="amount" required="true" type="DECIMAL" size="10" scale="2"/>
        <column name="status" required="true" type="VARCHAR" size="64"/>
        <column name="description" required="true" type="LONGVARCHAR"/>
        <column name="expiry_date" required="false" type="DATE"/>
        <column name="redirect_url" required="false" type="VARCHAR" size="500"/>
        <column name="is_reusable" required="false" type="BOOLEAN" default="false"/>
        <column name="payment_methods" required="false" type="LONGVARCHAR"/>
        <column name="mollie_payment_link_id" required="false" type="VARCHAR" size="255"/>
        <column name="payment_link_url" required="false" type="VARCHAR" size="500"/>

        <id-method-parameter value="spy_mollie_payment_link_pk_seq"/>

        <behavior name="timestampable"/>
    </table>

</database>
