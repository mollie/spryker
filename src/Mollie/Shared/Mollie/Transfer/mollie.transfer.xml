<?xml version="1.0"?>
<transfers xmlns="spryker:transfer-01" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="spryker:transfer-01 http://static.spryker.com/transfer-01.xsd">

    <transfer name="MollieCreditCardPayment">
        <property name="cardToken" type="string"/>
    </transfer>

    <transfer name="MolliePayPalPayment">
        <property name="sessionId" type="string"/>
        <property name="digitalGoods" type="bool"/>
    </transfer>

    <transfer name="MollieBankTransferPayment">
        <property name="dueDate" type="string"/>
        <property name="billingEmail" type="bool"/>
    </transfer>

    <transfer name="MollieKlarnaPayment">
        <property name="extraMerchantData" type="string"/>
    </transfer>

    <transfer name="MollieEpsPayment">
        <property name="extraMerchantData" type="string"/>
    </transfer>

    <transfer name="MollieIdealPayment">
        <property name="consumerDateOfBirth" type="string"/>
    </transfer>

    <transfer name="Payment">
        <property name="mollieCreditCardPayment" type="MollieCreditCardPayment"/>
        <property name="molliePayPalPayment" type="MolliePayPalPayment"/>
        <property name="mollieBankTransferPayment" type="MollieBankTransferPayment"/>
        <property name="mollieKlarnaPayment" type="MollieKlarnaPayment"/>
        <property name="mollieKlarnaPayLaterPayment" type="[]"/>
        <property name="mollieKlarnaPayNowPayment" type="[]"/>
        <property name="mollieKlarnaSliceItPayment" type="[]"/>
        <property name="mollieEpsPayment" type="[]"/>
        <property name="mollieIdealPayment" type="MollieIdealPayment"/>
        <property name="mollieBancontactPayment" type="[]"/>
        <property name="mollieKbcPayment" type="[]"/>
        <property name="molliePayByBankPayment" type="[]"/>
    </transfer>

    <transfer name="MolliePaymentMethod">
        <property name="id" type="string"/>
        <property name="description" type="string"/>
        <property name="locale" type="string"/>
        <property name="minimumAmount" type="array"/>
        <property name="maximumAmount" type="array"/>
        <property name="image" type="array"/>
        <property name="issuers" type="array"/>
        <property name="pricing" type="array"/>
        <property name="status" type="string"/>
    </transfer>

    <transfer name="MolliePaymentApiResponse">
        <property name="isSuccessful" type="bool"/>
        <property name="message" type="string"/>
        <property name="molliePayment" type="MolliePayment"/>
    </transfer>

    <transfer name="MolliePayment">
        <property name="resource" type="string"/>
        <property name="id" type="string"/>
        <property name="mode" type="string"/>
        <property name="amount" type="MollieAmount"/>
        <property name="description" type="string"/>
        <property name="sequenceType" type="string"/>
        <property name="redirectUrl" type="string"/>
        <property name="webhookUrl" type="string"/>
        <property name="metadata" type="array" singular="metadata"/>
        <property name="profileId" type="string"/>
        <property name="status" type="string"/>
        <property name="isCancelable" type="bool"/>
        <property name="createdAt" type="string"/>
        <property name="expiresAt" type="string"/>
        <property name="links" type="MollieLinks"/>
    </transfer>

    <transfer name="MollieRefundApiResponse">
        <property name="isSuccessful" type="bool"/>
        <property name="message" type="string"/>
        <property name="mollieRefund" type="MollieRefund"/>
    </transfer>

    <transfer name="MollieRefund">
        <property name="resource" type="string"/>
        <property name="id" type="string"/>
        <property name="mode" type="string"/>
        <property name="description" type="string"/>
        <property name="amount" type="MollieAmount"/>
        <property name="status" type="string"/>
        <property name="metadata" type="array" singular="metadata"/>
        <property name="paymentId" type="string"/>
        <property name="createdAt" type="string"/>
        <property name="links" type="MollieLinks"/>
    </transfer>

    <transfer name="MollieAmount">
        <property name="value" type="string"/>
        <property name="currency" type="string"/>
    </transfer>

    <transfer name="MollieLinks">
        <property name="self" type="MollieLink"/>
        <property name="checkout" type="MollieLink"/>
        <property name="dashboard" type="MollieLink"/>
        <property name="documentation" type="MollieLink"/>
        <property name="payment" type="MollieLink"/>
    </transfer>

    <transfer name="MollieLink">
        <property name="href" type="string"/>
        <property name="type" type="string"/>
    </transfer>

    <transfer name="OrderCollectionRequest">
        <property name="id" type="string" />
        <property name="status" type="string" />
    </transfer>

    <transfer name="OrderCollectionResponse">
        <property name="id" type="string" />
        <property name="isSuccess" type="bool" />
    </transfer>

    <transfer name="MolliePaymentMethodsApiResponse">
        <property name="isSuccessful" type="bool"/>
        <property name="message" type="string"/>
        <property name="collection" type="MolliePaymentMethodCollection"/>
    </transfer>

    <transfer name="MolliePaymentMethodCollection">
        <property name="methods" type="MolliePaymentMethod[]"/>
    </transfer>

    <transfer name="MolliePaymentMethodQueryParameters">
        <property name="locale" type="string"/>
        <property name="amount" type="MollieAmount"/>
        <property name="billingCountry" type="string"/>
        <property name="sequenceType" type="string"/>
        <property name="profileId" type="string"/>
        <property name="orderLineCategories" type="array"/>
        <property name="includeWallets" type="array"/>
        <property name="includeIssuers" type="bool"/>
        <property name="includePricing" type="bool"/>
    </transfer>

    <transfer name="MollieApiRequest">
        <property name="quote" type="Quote"/>
        <property name="checkoutResponse" type="CheckoutResponse"/>
        <property name="molliePaymentMethodQueryParameters" type="MolliePaymentMethodQueryParameters" />
        <property name="transactionId" type="string"/>
        <property name="description" type="string"/>
        <property name="metadata" type="array" singular="metadata"/>
    </transfer>

    <transfer name="MollieApiResponse">
        <property name="isSuccessful" type="bool"/>
        <property name="payload" type="array"/>
        <property name="code" type="int"/>
        <property name="message" type="string"/>
        <property name="timestamp" type="string"/>
    </transfer>

    <transfer name="Quote">
        <property name="molliePaymentId" type="string"/>
    </transfer>

    <transfer name="Order">
        <property name="molliePaymentId" type="string"/>
    </transfer>

    <transfer name="SaveOrder">
        <property name="molliePaymentId" type="string"/>
    </transfer>


</transfers>
