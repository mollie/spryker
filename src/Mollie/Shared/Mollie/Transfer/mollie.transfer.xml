<?xml version="1.0"?>
<transfers xmlns="spryker:transfer-01" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="spryker:transfer-01 http://static.spryker.com/transfer-01.xsd">

    <transfer name="MollieCreditCardPayment">
        <property name="cardToken" type="string"/>
    </transfer>

    <transfer name="Payment">
        <property name="mollieCreditCardPayment" type="MollieCreditCardPayment"/>
    </transfer>

    <transfer name="MolliePaymentMethod">
        <property name="id" type="string"/>
        <property name="description" type="string"/>
        <property name="minimumAmount" type="int"/>
        <property name="image" type="string"/>
        <property name="issuers" type="array"/>
        <property name="pricing" type="array"/>
        <property name="status" type="string"/>
    </transfer>

    <transfer name="MolliePaymentApiResponse">
        <property name="isSuccessful" type="bool"/>
        <property name="message" type="string"/>
        <property name="molliePayment" type="MolliePayment"/>
    </transfer>

    <transfer name="MolliePayment">
        <property name="resource" type="string"/>
        <property name="id" type="string"/>
        <property name="mode" type="string"/>
        <property name="amount" type="MollieAmount"/>
        <property name="description" type="string"/>
        <property name="sequenceType" type="string"/>
        <property name="redirectUrl" type="string"/>
        <property name="webhookUrl" type="string"/>
        <property name="metadata" type="array" singular="metadata"/>
        <property name="profileId" type="string"/>
        <property name="status" type="string"/>
        <property name="isCancelable" type="bool"/>
        <property name="createdAt" type="string"/>
        <property name="expiresAt" type="string"/>
        <property name="links" type="MollieLinks"/>
    </transfer>

    <transfer name="MollieAmount">
        <property name="value" type="string"/>
        <property name="currency" type="string"/>
    </transfer>

    <transfer name="MollieLinks">
        <property name="self" type="MollieLink"/>
        <property name="checkout" type="MollieLink"/>
        <property name="dashboard" type="MollieLink"/>
        <property name="documentation" type="MollieLink"/>
    </transfer>

    <transfer name="MollieLink">
        <property name="href" type="string"/>
        <property name="type" type="string"/>
    </transfer>

    <transfer name="MollieAvailablePaymentMethodCollection">
        <property name="methods" type="MolliePaymentMethod[]"/>
    </transfer>

    <transfer name="MollieApiRequest">
        <property name="quote" type="Quote"/>
        <property name="checkoutResponse" type="CheckoutResponse"/>
        <property name="paymentId" type="string"/>
    </transfer>

    <transfer name="MollieApiResponse">
        <property name="isSuccessful" type="bool"/>
        <property name="payload" type="string"/>
        <property name="code" type="int"/>
        <property name="message" type="string"/>
        <property name="timestamp" type="string"/>
    </transfer>

    <transfer name="MolliePayment">
        <property name="resource" type="string"/>
        <property name="id" type="string"/>
        <property name="mode" type="string"/>
        <property name="amount" type="array"/>
        <property name="settlementAmount" type="string"/>
        <property name="amountRefunded" type="string"/>
        <property name="amountRemaining" type="string"/>
        <property name="amountChargedBack" type="string"/>
        <property name="description" type="string"/>
        <property name="method" type="string"/>
        <property name="status" type="string"/>
        <property name="statusReason" type="string"/>
        <property name="createdAt" type="string"/>
        <property name="paidAt" type="string"/>
        <property name="canceledAt" type="string"/>
        <property name="expiresAt" type="string"/>
        <property name="failedAt" type="string"/>
        <property name="dueDate" type="string"/>
        <property name="billingEmail" type="string"/>
        <property name="profileId" type="string"/>
        <property name="sequenceType" type="string"/>
        <property name="redirectUrl" type="[]"/>
        <property name="cancelUrl" type="string"/>
        <property name="webhookUrl" type="string"/>
        <property name="mandateId" type="bool"/>
        <property name="subscriptionId" type="string"/>
        <property name="orderId" type="string"/>
        <property name="lines" type="string"/>
        <property name="billingAddress" type="string"/>
        <property name="shippingAddress" type="string"/>
        <property name="settlementId" type="string"/>
        <property name="metadata" type="array"/>
        <property name="details" type="string"/>
        <property name="restrictPaymentMethodsToCountry" type="string"/>
        <property name="links" type="array"/>
        <property name="embedded" type="string"/>
        <property name="isCancelable" type="string"/>
        <property name="amountCaptured" type="string"/>
        <property name="captureMode" type="string"/>
        <property name="captureDelay" type="string"/>
        <property name="captureBefore" type="string"/>
        <property name="applicationFee" type="string"/>
        <property name="routing" type="string"/>
        <property name="authorizedAt" type="string"/>
        <property name="expiredAt" type="string"/>
        <property name="customerId" type="string"/>
        <property name="countryCode" type="string"/>
    </transfer>

    <transfer name="Quote">
        <property name="molliePaymentId" type="string"/>
    </transfer>

    <transfer name="Order">
        <property name="molliePaymentId" type="string"/>
    </transfer>

    <transfer name="SaveOrder">
        <property name="molliePaymentId" type="string"/>
    </transfer>


</transfers>
